    "@prisma/client": "^7.7.0",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.0",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
